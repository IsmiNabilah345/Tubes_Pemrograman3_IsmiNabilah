{
  "name": "ws2026",
  "version": "0.1.0",
  "private": true,
  "description": "Tutorial praktik Web Service berbasis Node.js, Express, dan TypeScript.",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:inventory",
    "dev:auth": "tsx watch src/auth-service/server.ts",
    "dev:inventory": "tsx watch src/inventory-service/server.ts",
    "build": "tsc",
    "start:auth": "node dist/auth-service/server.js",
    "start:inventory": "node dist/inventory-service/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
